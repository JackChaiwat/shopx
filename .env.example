# ============================================================
# ECOMMERCE PLATFORM - ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in production values
# ============================================================

# --- App ---
APP_ENV=
APP_SECRET_KEY=change-me
APP_DEBUG=
APP_VERSION=

# --- Backend ---
BACKEND_HOST=
BACKEND_PORT=
BACKEND_WORKERS=
ALLOWED_ORIGINS=

# --- Frontend ---
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
