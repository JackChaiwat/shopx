# --- JWT ---
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=change-me
JWT_REFRESH_TOKEN_EXPIRE_DAYS=change-me

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=
